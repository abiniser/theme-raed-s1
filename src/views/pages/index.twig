{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}

    {# 1. Hero Banner #}
    <section style="position:relative; width:100%; min-height:500px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
        <div style="position:absolute; inset:0; z-index:0;">
            <img src="{{ 'images/hero-banner.jpg' | asset }}" alt="Sabaq Al-Oula" style="width:100%; height:100%; object-fit:cover; display:block;">
            <div style="position:absolute; inset:0; background: linear-gradient(to top, rgba(15,58,40,0.85), rgba(23,78,54,0.3));"></div>
        </div>
        <div class="container" style="position:relative; z-index:10; text-align:center; color:#fff; padding:60px 16px 40px;">
            <h1 style="font-size:2.5rem; font-weight:700; margin-bottom:16px; text-shadow: 0 2px 8px rgba(0,0,0,0.3); font-family: 'Alexandria', sans-serif;">رحلتك تبدأ من هنا</h1>
            <p style="font-size:1.25rem; margin-bottom:32px; font-weight:300; color:#e5e7eb;">المعدات الاحترافية لرحلات ومغامرات لا تُنسى</p>
            <a href="{{ store.url }}" style="display:inline-block; background:#D4AF37; color:#0F3A28; font-weight:700; font-size:1.1rem; padding:12px 32px; border-radius:6px; box-shadow:0 4px 15px rgba(0,0,0,0.2); border:1px solid #E6C76A; text-decoration:none;">تسوق الآن</a>
        </div>
    </section>

    {# 2. Categories Section (Ultra Modern Design) #}
    <section style="padding:80px 0;">
        <div class="container">
            <div style="text-align:center; margin-bottom:40px;">
                <h2 style="font-size:2rem; font-weight:700; color:#fff; margin-bottom:8px;">اكتشف الأقسام</h2>
                <div style="width:60px; height:4px; background:#D4AF37; margin:0 auto; border-radius:2px;"></div>
            </div>
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:24px; padding:0 16px;">
                
                {# Category 1: Camping #}
                <a href="{{ store.url }}" style="display:block; text-decoration:none; group; position:relative; overflow:hidden; border-radius:16px; background:#fff; box-shadow:0 10px 30px rgba(15,58,40,0.05); transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border:1px solid rgba(15,58,40,0.05);" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 20px 40px rgba(15,58,40,0.12)'; this.style.borderColor='rgba(212,175,55,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(15,58,40,0.05)'; this.style.borderColor='rgba(15,58,40,0.05)';">
                    <div style="padding:40px 24px; display:flex; flex-direction:column; align-items:center; text-align:center;">
                        <div style="width:80px; height:80px; border-radius:40px; background:rgba(47,111,85,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:24px; color:#4ADE80; transition:all 0.3s ease;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 22h20L12 2z"></path>
                                <path d="M12 15v7"></path>
                            </svg>
                        </div>
                        <h3 style="font-weight:700; font-size:1.15rem; color:#0F3A28; margin-bottom:8px;">مستلزمات التخييم</h3>
                        <p style="font-size:0.9rem; color:#6B7280;">معدات النجاة والمبيت</p>
                    </div>
                </a>

                {# Category 2: Off-road #}
                <a href="{{ store.url }}" style="display:block; text-decoration:none; group; position:relative; overflow:hidden; border-radius:16px; background:#fff; box-shadow:0 10px 30px rgba(15,58,40,0.05); transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border:1px solid rgba(15,58,40,0.05);" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 20px 40px rgba(15,58,40,0.12)'; this.style.borderColor='rgba(212,175,55,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(15,58,40,0.05)'; this.style.borderColor='rgba(15,58,40,0.05)';">
                    <div style="padding:40px 24px; display:flex; flex-direction:column; align-items:center; text-align:center;">
                        <div style="width:80px; height:80px; border-radius:40px; background:rgba(212,175,55,0.2); display:flex; align-items:center; justify-content:center; margin-bottom:24px; color:#D4AF37; transition:all 0.3s ease;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <circle cx="12" cy="12" r="4"></circle>
                                <path d="M12 2v2"></path>
                                <path d="M12 20v2"></path>
                                <path d="M4 12H2"></path>
                                <path d="M22 12h-2"></path>
                            </svg>
                        </div>
                        <h3 style="font-weight:700; font-size:1.15rem; color:#0F3A28; margin-bottom:8px;">معدات الطرق</h3>
                        <p style="font-size:0.9rem; color:#6B7280;">للقيادة في التضاريس الوعرة</p>
                    </div>
                </a>

                {# Category 3: Power #}
                <a href="{{ store.url }}" style="display:block; text-decoration:none; group; position:relative; overflow:hidden; border-radius:16px; background:#fff; box-shadow:0 10px 30px rgba(15,58,40,0.05); transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border:1px solid rgba(15,58,40,0.05);" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 20px 40px rgba(15,58,40,0.12)'; this.style.borderColor='rgba(212,175,55,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(15,58,40,0.05)'; this.style.borderColor='rgba(15,58,40,0.05)';">
                    <div style="padding:40px 24px; display:flex; flex-direction:column; align-items:center; text-align:center;">
                        <div style="width:80px; height:80px; border-radius:40px; background:rgba(47,111,85,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:24px; color:#4ADE80; transition:all 0.3s ease;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
                            </svg>
                        </div>
                        <h3 style="font-weight:700; font-size:1.15rem; color:#0F3A28; margin-bottom:8px;">طاقة وبطاريات</h3>
                        <p style="font-size:0.9rem; color:#6B7280;">حلول طاقة مستدامة للمخيم</p>
                    </div>
                </a>

                {# Category 4: Observation #}
                <a href="{{ store.url }}" style="display:block; text-decoration:none; group; position:relative; overflow:hidden; border-radius:16px; background:#fff; box-shadow:0 10px 30px rgba(15,58,40,0.05); transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border:1px solid rgba(15,58,40,0.05);" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 20px 40px rgba(15,58,40,0.12)'; this.style.borderColor='rgba(212,175,55,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(15,58,40,0.05)'; this.style.borderColor='rgba(15,58,40,0.05)';">
                    <div style="padding:40px 24px; display:flex; flex-direction:column; align-items:center; text-align:center;">
                        <div style="width:80px; height:80px; border-radius:40px; background:rgba(212,175,55,0.2); display:flex; align-items:center; justify-content:center; margin-bottom:24px; color:#D4AF37; transition:all 0.3s ease;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </div>
                        <h3 style="font-weight:700; font-size:1.15rem; color:#0F3A28; margin-bottom:8px;">رصد واستكشاف</h3>
                        <p style="font-size:0.9rem; color:#6B7280;">أجهزة اتصال ونواظير</p>
                    </div>
                </a>

            </div>
        </div>
    </section>

    {# 3. Two Banners #}
    <section style="padding:48px 0;">
        <div class="container">
            <salla-slider type="carousel" id="sabaq-main-banners" autoplay loop>
                <div slot="items">
                    <div class="swiper-slide" style="position:relative; border-radius:12px; overflow:hidden; box-shadow:0 15px 35px rgba(0,0,0,0.1);">
                         <a href="{{ store.url }}" style="display:block; width:100%;">
                             <img src="{{ 'images/rotating-banner-1.jpg' | asset }}" style="width:100%; height:auto; display:block; transition:transform 0.5s ease;" onmouseover="this.style.transform='scale(1.02)';" onmouseout="this.style.transform='scale(1)';" alt="Banner 1">
                         </a>
                    </div>
                    <div class="swiper-slide" style="position:relative; border-radius:12px; overflow:hidden; box-shadow:0 15px 35px rgba(0,0,0,0.1);">
                         <a href="{{ store.url }}" style="display:block; width:100%;">
                             <img src="{{ 'images/rotating-banner-2.jpg' | asset }}" style="width:100%; height:auto; display:block; transition:transform 0.5s ease;" onmouseover="this.style.transform='scale(1.02)';" onmouseout="this.style.transform='scale(1)';" alt="Banner 2">
                         </a>
                    </div>
                </div>
            </salla-slider>
        </div>
    </section>

    {# 4. Products section header #}
    <section style="padding:32px 0 0;">
        <div class="container">
            <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:24px; border-bottom:2px solid rgba(212,175,55,0.3); padding-bottom:12px;">
                <div style="display:flex; align-items:center; gap:12px;">
                    <span style="width:4px; height:32px; background:#D4AF37; display:block; border-radius:2px;"></span>
                    <h2 style="font-size:1.5rem; font-weight:700; color:#fff;">منتجات مختارة</h2>
                </div>
                <a href="{{ store.url }}" style="color:#2F6F55; font-weight:600; font-size:0.9rem; text-decoration:none;">
                    عرض الكل ←
                </a>
            </div>
        </div>
    </section>

    {# 5. Standard Salla home components (renders products from your store dashboard) #}
    {% component home %}

    {# 6. Payment Methods Highlight Section (Premium & Animated) #}
    <section style="padding:80px 0; background:#023017; border-top:1px solid rgba(255,255,255,0.1);">
        <div class="container">
            <div style="text-align:center; margin-bottom:50px;">
                <h2 style="font-size:2rem; font-weight:800; color:#fff; margin-bottom:12px; font-family: 'Alexandria', sans-serif;">تسوق بمرونة وسهولة</h2>
                <p style="font-size:1.1rem; color:#e5e7eb; max-width:600px; margin:0 auto;">ونوفر لك أحدث حلول الدفع الآمنة والتقسيط المريح لتجربة تسوق لا تضاهى</p>
                <div style="width:80px; height:4px; background:#D4AF37; margin:20px auto 0; border-radius:10px;"></div>
            </div>

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:24px; padding:0 20px;">
                
                {# Tabby Card - Highlighted #}
                <div style="background:#fff; border-radius:20px; padding:32px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.05); border:2px solid #D4AF37; position:relative; overflow:hidden; transition:all 0.4s ease; cursor:default;" onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(212,175,55,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.05)';">
                    <div style="position:absolute; top:15px; left:-18px; background:#D4AF37; color:#0F3A28; padding:4px 30px; transform:rotate(-45deg); font-weight:800; font-size:0.75rem; box-shadow:0 2px 8px rgba(0,0,0,0.15);">تقسيط</div>
                    <div style="height:90px; display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
                        <img src="{{ 'images/tabby.png' | asset }}" alt="Tabby" style="max-height:100%; width:auto; max-width:220px; object-fit:contain;">
                    </div>
                    <h3 style="font-size:1.3rem; font-weight:800; color:#0F3A28; margin-bottom:12px; font-family: 'Alexandria', sans-serif;">تابي | Tabby</h3>
                    <p style="font-size:0.95rem; color:#4b5563; line-height:1.5;">قسم مشترياتك على 4 دفعات شهرية بدون فوائد أو رسوم إضافية</p>
                </div>

                {# Tamara Card - Highlighted #}
                <div style="background:#fff; border-radius:20px; padding:32px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.05); border:2px solid #D4AF37; position:relative; overflow:hidden; transition:all 0.4s ease; cursor:default;" onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(212,175,55,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.05)';">
                    <div style="position:absolute; top:15px; left:-18px; background:#D4AF37; color:#0F3A28; padding:4px 30px; transform:rotate(-45deg); font-weight:800; font-size:0.75rem; box-shadow:0 2px 8px rgba(0,0,0,0.15);">تقسيط</div>
                    <div style="height:90px; display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
                        <img src="{{ 'images/tamara.svg' | asset }}" alt="Tamara" style="max-height:100%; width:auto; max-width:220px; object-fit:contain;">
                    </div>
                    <h3 style="font-size:1.3rem; font-weight:800; color:#0F3A28; margin-bottom:12px; font-family: 'Alexandria', sans-serif;">تمارا | Tamara</h3>
                    <p style="font-size:0.95rem; color:#4b5563; line-height:1.5;">تسوق الآن وادفع لاحقاً عبر تمارا. قسّم مبالغك بسهولة تامة وبكل أمان</p>
                </div>

                {# Apple Pay Card #}
                <div style="background:#fff; border-radius:20px; padding:32px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.05); border:1px solid #e5e7eb; transition:all 0.4s ease; cursor:default;" onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.08)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.05)';">
                    <div style="height:90px; display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
                        <img src="{{ 'images/apple-pay.png' | asset }}" alt="Apple Pay" style="max-height:85%; width:auto; max-width:140px; object-fit:contain;">
                    </div>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#0F3A28; margin-bottom:12px; font-family: 'Alexandria', sans-serif;">آبل باي | Apple Pay</h3>
                    <p style="font-size:0.9rem; color:#4b5563; line-height:1.5;">أسهل وأسرع طريقة للدفع بضغطة زر واحدة بكل أمان وخصوصية</p>
                </div>

                {# Mada Card #}
                <div style="background:#fff; border-radius:20px; padding:32px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.05); border:1px solid #e5e7eb; transition:all 0.4s ease; cursor:default;" onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.08)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.05)';">
                    <div style="height:90px; display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
                        <img src="{{ 'images/mada.svg' | asset }}" alt="Mada" style="max-height:85%; width:auto; max-width:140px; object-fit:contain;">
                    </div>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#0F3A28; margin-bottom:12px; font-family: 'Alexandria', sans-serif;">بطاقات مدى | Mada</h3>
                    <p style="font-size:0.9rem; color:#4b5563; line-height:1.5;">الدفع عبر الشبكة السعودية للمدفوعات متاح لجميع عملاء البنوك المحلية</p>
                </div>

            </div>
        </div>
    </section>

{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}