{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}

    {# 1. Hero Banner #}
    <section class="sabaq-hero relative w-full h-[80vh] min-h-[500px] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="{{ 'images/hero-banner.jpg' | asset }}" alt="Sabaq Al-Oula" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0F3A28]/80 to-[#174E36]/30"></div>
        </div>
        <div class="container relative z-10 text-center text-white mt-16 px-4">
            <h1 class="text-4xl md:text-6xl font-bold mb-4 drop-shadow-md">رحلتك تبدأ من هنا</h1>
            <p class="text-lg md:text-2xl mb-8 font-light text-gray-200">المعدات الاحترافية لرحلات ومغامرات لا تُنسى</p>
            <a href="{{ link('/') }}products" class="inline-block bg-[#D4AF37] text-[#0F3A28] font-bold text-lg px-8 py-3 rounded-md shadow-lg hover:bg-[#E6C76A] transition-colors border border-[#E6C76A]">تسوق الآن</a>
        </div>
    </section>

    {# 2. Categories Section (Technical Icons) #}
    <section class="sabaq-categories py-12 bg-[#F2F2F2]">
        <div class="container">
            <salla-slider type="carousel" id="sabaq-categories-slider">
                <div slot="items" class="py-4">
                        <div class="swiper-slide">
                            <a href="{{ link('/') }}categories" class="flex flex-col items-center group cursor-pointer">
                                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-md border border-gray-200 mb-3 text-[#2F6F55] group-hover:bg-[#2F6F55] group-hover:border-[#D4AF37] group-hover:text-white transition-all transform group-hover:-translate-y-1">
                                   <i class="sicon-walk text-3xl"></i>
                                </div>
                                <h3 class="font-bold text-[#0F3A28] text-sm md:text-base">مستلزمات التخييم</h3>
                            </a>
                        </div>
                        <div class="swiper-slide">
                            <a href="{{ link('/') }}categories" class="flex flex-col items-center group">
                                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-md border border-gray-200 mb-3 text-[#2F6F55] group-hover:bg-[#2F6F55] group-hover:border-[#D4AF37] group-hover:text-white transition-all">
                                   <i class="sicon-car text-3xl"></i>
                                </div>
                                <h3 class="font-bold text-[#0F3A28]">معدات الطرق</h3>
                            </a>
                        </div>
                         <div class="swiper-slide">
                            <a href="{{ link('/') }}categories" class="flex flex-col items-center group">
                                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-md border border-gray-200 mb-3 text-[#2F6F55] group-hover:bg-[#2F6F55] group-hover:border-[#D4AF37] group-hover:text-white transition-all">
                                   <i class="sicon-battery text-3xl"></i>
                                </div>
                                <h3 class="font-bold text-[#0F3A28]">طاقة وبطاريات</h3>
                            </a>
                        </div>
                         <div class="swiper-slide">
                            <a href="{{ link('/') }}categories" class="flex flex-col items-center group">
                                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-md border border-gray-200 mb-3 text-[#2F6F55] group-hover:bg-[#2F6F55] group-hover:border-[#D4AF37] group-hover:text-white transition-all">
                                   <i class="sicon-camera text-3xl"></i>
                                </div>
                                <h3 class="font-bold text-[#0F3A28]">رصد و استكشاف</h3>
                            </a>
                        </div>
                </div>
            </salla-slider>
        </div>
    </section>

    {# 3. Two Rotating Banners #}
    <section class="sabaq-rotating-banners py-12">
        <div class="container">
            <salla-slider type="carousel" id="sabaq-main-banners" autoplay="true" loop="true">
                <div slot="items" class="pb-8">
                    <div class="swiper-slide relative rounded-lg overflow-hidden h-[300px] md:h-[450px]">
                         <img src="{{ 'images/rotating-banner-1.jpg' | asset }}" class="w-full h-full object-cover" alt="Banner 1">
                         <div class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center px-4">
                             <div class="text-center text-white max-w-lg p-6 backdrop-blur-md bg-[#0F3A28]/60 rounded-xl border border-[#D4AF37]/50 shadow-2xl">
                                 <h2 class="text-2xl md:text-3xl font-bold mb-3 font-en tracking-wide">Field-Tested Reliability</h2>
                                 <p class="text-sm md:text-lg text-gray-200 mb-4 font-ar">أجهزة اتصال توفر دقة لا تخطئ في أحلك الظروف البيئية.</p>
                                 <a href="{{ link('/') }}products" class="text-[#D4AF37] hover:text-white font-bold inline-flex items-center gap-1 transition-colors">
                                     اكتشف تشكيلتنا
                                     <i class="sicon-keyboard_arrow_left"></i>
                                 </a>
                             </div>
                         </div>
                    </div>
                    <div class="swiper-slide relative rounded-lg overflow-hidden h-[300px] md:h-[450px]">
                         <img src="{{ 'images/rotating-banner-2.jpg' | asset }}" class="w-full h-full object-cover" alt="Banner 2">
                         <div class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center px-4">
                             <div class="text-center text-white max-w-lg p-6 backdrop-blur-md bg-[#0F3A28]/60 rounded-xl border border-[#D4AF37]/50 shadow-2xl">
                                 <h2 class="text-2xl md:text-3xl font-bold mb-3 font-en tracking-wide">Extreme Endurance</h2>
                                 <p class="text-sm md:text-lg text-gray-200 mb-4 font-ar">معدات مصممة لتحمل أقسى التضاريس والطرق الوعرة.</p>
                                 <a href="{{ 'products'|link }}" class="text-[#D4AF37] hover:text-white font-bold inline-flex items-center gap-1 transition-colors">
                                     تسوق الآن
                                     <i class="sicon-keyboard_arrow_left"></i>
                                 </a>
                             </div>
                         </div>
                    </div>
                </div>
            </salla-slider>
        </div>
    </section>

    {# 4. Selected Products #}
    <section class="sabaq-featured-products py-12 bg-white">
        <div class="container">
            <div class="flex justify-between items-end mb-8 border-b-2 border-[#0F3A28] pb-2">
                <div class="flex items-center gap-3">
                    <span class="w-2 h-8 bg-[#D4AF37] block rounded-sm"></span>
                    <h2 class="text-2xl font-bold text-[#0F3A28]">أحدث المعدات الاحترافية</h2>
                </div>
                <a href="{{ link('/') }}products" class="text-[#2F6F55] hover:text-[#0F3A28] font-semibold flex items-center text-sm transition-colors opacity-80 hover:opacity-100">
                    عرض الكل
                    <i class="sicon-keyboard_arrow_left rtl:mr-1 ltr:rotate-180"></i>
                </a>
            </div>
            
            <salla-products-list source="latest" limit="8">
                <template>
                    <custom-salla-product-card shadow-on-hover class="border border-gray-100 rounded-lg hover:border-[#D4AF37]/40 transition-colors"></custom-salla-product-card>
                </template>
            </salla-products-list>
        </div>
    </section>

    {# Fallback to standard theme components #}
    <div class="bg-[#F2F2F2] py-8">
        {% component home %}
    </div>
    
{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
    <style>
        .font-en { font-family: var(--font-en); }
        .font-ar { font-family: var(--font-ar); }
    </style>
{% endblock %}